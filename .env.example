# Copy to `.env` (git-ignored) for local dev.
# In prod, set these via `flyctl secrets set KEY=VALUE`.

# ── Supabase (required for live mode; omit for demo mode) ─────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJI...
# Service-role key — keep secret, only used to upsert public.users at signup.
SUPABASE_SERVICE_KEY=eyJhbGciOiJI...

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
NOTIFICATIONS_FROM_EMAIL=marketplace@yourdomain.com

# ── WhatsApp (Twilio) — optional ──────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Public base URL (used in notification deep-links) ─────────────────────────
PUBLIC_BASE_URL=https://event-sponsor-marketplace.fly.dev
